rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Demo-only rules: tighten before any public release (use auth + per-user checks).
    match /clash_matches/{matchId} {
      allow read, write: if true;
    }
    match /battle_queue/{docId} {
      allow read, write: if true;
    }
    match /battle_matches/{matchId} {
      allow read, write: if true;
      match /moves/{moveId} {
        allow read, write: if true;
      }
      match /emotes/{emoteId} {
        allow read, write: if true;
      }
    }
    match /player_slots/{guestId} {
      allow read, write: if true;
    }
  }
}
